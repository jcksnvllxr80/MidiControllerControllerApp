{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MidiController Controller",
  "version": "0.1.0",
  "identifier": "com.aaronwatkins.midicontroller.controller",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MidiController Controller",
        "width": 980,
        "height": 740,
        "minWidth": 720,
        "minHeight": 560,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "shortDescription": "Configure and control the MidiController",
    "longDescription": "Native desktop app to set up and play your MidiController over USB or Wi-Fi.",
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
